{
    "name": "7amoood/laravel-appsync-broadcaster",
    "description": "AWS AppSync broadcaster for Laravel Broadcasting - Real-time communication using AWS AppSync Events API",
    "type": "library",
    "keywords": [
        "laravel",
        "broadcasting",
        "appsync",
        "aws",
        "realtime",
        "event api",
        "subscriptions",
        "websockets",
        "pusher",
        "ably",
        "replacement of pusher"
    ],
    "license": "MIT",
    "authors": [
        {
            "name": "Mohamed AbdElfattah",
            "email": "mohamed.abdelfattah.ragab@gmail.com"
        }
    ],
    "require": {
        "php": "^8.1",
        "illuminate/broadcasting": "^10.0|^11.0|^12.0",
        "illuminate/cache": "^10.0|^11.0|^12.0",
        "illuminate/console": "^10.0|^11.0|^12.0",
        "illuminate/http": "^10.0|^11.0|^12.0",
        "illuminate/redis": "^10.0|^11.0|^12.0",
        "illuminate/support": "^10.0|^11.0|^12.0",
        "nesbot/carbon": "^2.0|^3.0",
        "react/event-loop": "^1.5",
        "ratchet/pawl": "^0.4",
        "clue/redis-react": "^2.7"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0|^11.0",
        "orchestra/testbench": "^8.0|^9.0|^10.0"
    },
    "autoload": {
        "psr-4": {
            "Hamoood\\LaravelAppSyncBroadcaster\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Hamoood\\LaravelAppSyncBroadcaster\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Hamoood\\LaravelAppSyncBroadcaster\\AppSyncBroadcastServiceProvider"
            ]
        }
    },
    "scripts": {
        "test": "phpunit",
        "test-coverage": "phpunit --coverage-html build/coverage",
        "format": "php-cs-fixer fix",
        "analyse": "phpstan analyse"
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}